{
  "name": "asgard",
  "tools": {
    "claude": {
      "binary": "claude",
      "args": ["-p", "{prompt}", "--print", "--dangerously-skip-permissions"],
      "model_flag": "--model"
    },
    "gemini-cli": {
      "binary": "gemini",
      "args": ["-p", "{prompt}", "--yolo"],
      "model_flag": "--model"
    },
    "opencode": {
      "binary": "opencode",
      "args": ["run", "{prompt}"],
      "model_flag": "-m"
    },
    "ollama": {
      "binary": "ollama",
      "args": ["run", "{model}", "{prompt}"],
      "model_flag": null
    }
  },
  "defaults": {
    "tool": "claude",
    "model": "sonnet",
    "timeout_seconds": 300,
    "terminate_after": true
  },
  "orchestrator": {
    "poll_ms": 1000,
    "ack_timeout_ms": 30000,
    "exec_warning_ms": 600000,
    "zombie_kill_ms": 1800000,
    "max_spawn_depth": 1,
    "max_spawns_per_agent": 10,
    "log_max_bytes": 10485760,
    "log_json_mode": false,
    "archive_days": 7,
    "auto_synthesize": false,
    "enable_surveys": false,
    "load_throttle": {
      "enabled": true,
      "max_concurrent": 5,
      "check_interval_ms": 2000
    }
  }
}
